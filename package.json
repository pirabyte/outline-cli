{
  "name": "outline-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-friendly CLI for Outline document CRUD operations",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "bin": {
    "outline": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs/PRD.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "prepublishOnly": "bun run build",
    "release:checksums": "shasum -a 256 release/* > release/SHA256SUMS.txt"
  },
  "dependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
